# 複製這個檔案為 .env，再把金鑰貼進去（.env 不會被 git 追蹤）
# 取得金鑰：https://aistudio.google.com/apikey

GEMINI_API_KEY=在這裡貼上你的金鑰

# 可選：模型名稱，預設 gemini-3.5-flash（尖峰 503 時後端會自動降級）
GEMINI_MODEL=gemini-3.5-flash
# 主模型忙碌或下架時的備援（逗號分隔）
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.5-flash-lite

# 可選：伺服器埠號，預設 8787
PORT=8787

# ── Google OAuth（Google Cloud Console → 憑證 → OAuth 2.0 用戶端）──
# 類型選「網頁應用程式」；已授權的 JavaScript 來源需包含：
#   http://localhost:8787
#   https://你的-render-網域.onrender.com
GOOGLE_CLIENT_ID=在這裡貼上你的_Client_ID.apps.googleusercontent.com

# JWT 簽章密鑰（請用隨機長字串；Render 後台也要設同一組，且部署後不可變更）
# 可設 JWT_SECRET 或 NEXTAUTH_SECRET（二擇一，值必須固定）
JWT_SECRET=zodiac_warrior_secret_key_2026

# ── 資料庫（生產環境必填）──
# 本機開發可留空 → 自動使用 data/users.json
# Render 部署請在 Blueprint 綁定 PostgreSQL，或手動貼上 External Database URL
# DATABASE_URL=postgresql://user:pass@dpg-xxx-a.oregon-postgres.render.com/dbname
# 若內網短 hostname（dpg-xxx-a）連線失敗，可另設外部連線字串作為備援：
# DATABASE_EXTERNAL_URL=postgresql://user:pass@dpg-xxx-a.oregon-postgres.render.com/dbname

# 可選：JWT 有效期限。預設 none = 永久有效（除非你手動登出）
# 若要限期可設 30d、365d 等
JWT_EXPIRES=none

# Beta 測試：記帳頁「免費領 100 硬幣」除錯按鈕（設 false 可於正式上線前關閉）
ENABLE_BETA_DEBUG=true
